<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers.ItemDetailController" spacing="20" alignment="TOP_CENTER">
    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <HBox alignment="CENTER_LEFT">
        <Button text="&lt; Back to List" onAction="#navigateBack" style="-fx-background-color: transparent; -fx-text-fill: #0d6efd;" />
    </HBox>

    <Label fx:id="titleLabel" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
    
    <ImageView fx:id="itemImageView" fitWidth="300" fitHeight="250" preserveRatio="true" />
    
    <VBox spacing="10" alignment="CENTER_LEFT" maxWidth="500">
        <Label fx:id="priceLabel" style="-fx-font-size: 18px; -fx-text-fill: #198754; -fx-font-weight: bold;" />
        <Label fx:id="conditionLabel" style="-fx-font-size: 14px;" />
        <Label fx:id="sellerLabel" style="-fx-font-size: 14px; -fx-text-fill: #6c757d;" />
        <Label fx:id="statusLabel" style="-fx-font-size: 14px;" />
        <Label text="Description:" style="-fx-font-weight: bold; -fx-font-size: 16px;" />
        <Label fx:id="descriptionLabel" wrapText="true" style="-fx-font-size: 14px;" />
    </VBox>
    
    <Button fx:id="buyButton" text="Buy Now" onAction="#handleBuyAction" style="-fx-background-color: #198754; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10 20;" />
    
    <Label fx:id="actionStatusLabel" visible="false" />
</VBox>
