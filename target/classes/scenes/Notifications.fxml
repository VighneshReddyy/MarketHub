<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.controllers.NotificationController" spacing="15">
    <padding><Insets top="20" right="40" bottom="20" left="40"/></padding>
    
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="&lt; Back to Dashboard" onAction="#navigateBack" style="-fx-background-color: transparent; -fx-text-fill: #0d6efd;" />
        <Region HBox.hgrow="ALWAYS" />
        <Label text="Notifications" styleClass="title-label" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Refresh" onAction="#loadNotifications" />
    </HBox>

    <ListView fx:id="notificationList" VBox.vgrow="ALWAYS" prefHeight="400" />
    
    <Label fx:id="statusLabel" visible="false" />
    <Button text="Mark Selected as Read" onAction="#handleMarkAsRead" alignment="CENTER" />
</VBox>
